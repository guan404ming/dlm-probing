\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Full steering intervention summary on LLaDA-8B / MBPP; entries show flips / evaluated cases over all $152$ fail samples ($126$ cluster-1 + $26$ cluster-0) and $50$ pass-side regression controls. Suppress \texttt  {f15601} or the top-5 features at step 64 (within the plateau) is fully null at $0/202$; suppress \texttt  {f15601} from step 16 (before plateau formation) produces a small $3/202$ effect ($1.5\%$, both fail$\to $pass conversions occur on cluster-1 cases). Reverse intervention ($\alpha \!=\!-5$) is null.}}{3}{table.caption.13}\protected@file@percent }
\newlabel{tab:steering}{{1}{3}{Full steering intervention summary on LLaDA-8B / MBPP; entries show flips / evaluated cases over all $152$ fail samples ($126$ cluster-1 + $26$ cluster-0) and $50$ pass-side regression controls. Suppress \texttt {f15601} or the top-5 features at step 64 (within the plateau) is fully null at $0/202$; suppress \texttt {f15601} from step 16 (before plateau formation) produces a small $3/202$ effect ($1.5\%$, both fail$\to $pass conversions occur on cluster-1 cases). Reverse intervention ($\alpha \!=\!-5$) is null}{table.caption.13}{}}
